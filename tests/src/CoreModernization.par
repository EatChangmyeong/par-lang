module CoreModernization

import {
  @core/Bool
  @core/BoxMap
  @core/Bytes
  @core/Char
  @core/Float
  @core/Int
  @core/Json
  @core/List
  @core/Map
  @core/Nat
  @core/Option
  @core/Stream
  @core/String
  @core/Test
  @core/Try
}

type Key = (Nat) Nat
type PairList = List<(Key) String>

def KeyA : Key = (1) 2
def KeyB : Key = (0) 3
def KeyC : Key = (2) 0

dec MapLookupThenList : [Map<Key, String>, Key] (Option<String>) PairList
def MapLookupThenList = [map, key] do {
  map.entry(key)[entry]
  map.delete
  let entries = map.list
} in (entry) entries

dec MapSizeThenList : [Map<Key, String>] (Nat) PairList
def MapSizeThenList = [map] do {
  map.size[size]
  let entries = map.list
} in (size) entries

dec MapPutList : [!] PairList
def MapPutList = [!] do {
  let map = Map.New(type Key, type String)
  map.entry(KeyA)[entry]
  entry.case {
    .some old => { map.put(old) },
    .none! => { map.put("one") },
  }
  let entries = map.list
} in entries

def TestListConstraintsAndEquality : [Test] ! = [test] do {
  let values = *(1, 2, 3, 4)
  let evens = values->List.Filter(box [n] n / 2 * 2 == n)
  let firstTwo = values->List.Take(2)
  let withoutTwo = values->List.Drop(2)
  let zipped = firstTwo->List.Zip(*("one", "two", "three"))
  let sum = {0}->List.ForEach(values, box [sum, n] sum + n)
  let builder = List.Builder(type Nat)
  builder->List.ForEach(values, box [b, n] b.add(n * 2))
  let doubled = builder.build

  test
    .assert("List equality uses generic data equality", values == {*(1, 2, 3, 4)})
    .assert("List.Filter accepts a box-constrained element type", evens == {*(2, 4)})
    .assert("List.Length accepts a box-constrained element type", values->List.Length == 4)
    .assert("List.Zip accepts box-constrained element types", zipped == {*((1) "one", (2) "two")})
    .assert("List.All accepts a box-constrained element type", values->List.All(box [n] n > 0))
    .assert("List.Any accepts a box-constrained element type", values->List.Any(box [n] n == 3))
    .assert("List.Take accepts a box-constrained element type", firstTwo == {*(1, 2)})
    .assert("List.Drop accepts a box-constrained element type", withoutTwo == {*(3, 4)})
    .assert("List.ForEach works in expression syntax", sum == 10)
    .assert("List.ForEach works in process syntax", doubled == {*(2, 4, 6, 8)})
} in !

def TestListSorting : [Test] ! = [test] do {
  let numbers = *(3, 1, 2, 1)
  let tagged = *((2) "first-two", (1) "one", (2) "second-two", (0) "zero")
  let sortedTagged = tagged->List.SortBy(box [(key) _] key)
  let linearSortedTagged = tagged->List.SortLinearBy(box [item]
    let (key) _ = item in
    (key) item
  )
  let linearDescTagged = tagged->List.SortLinearDescBy(box [item]
    let (key) _ = item in
    (key) item
  )

  test
    .assert("List.Sort orders data ascending", numbers->List.Sort == {*(1, 1, 2, 3)})
    .assert("List.SortDesc orders data descending", numbers->List.SortDesc == {*(3, 2, 1, 1)})
    .assert(
      "List.SortBy is stable for equal keys",
      sortedTagged == {*((0) "zero", (1) "one", (2) "first-two", (2) "second-two")},
    )
    .assert(
      "List.SortLinearBy sorts by returned keys",
      linearSortedTagged == {*((0) "zero", (1) "one", (2) "first-two", (2) "second-two")},
    )
    .assert(
      "List.SortLinearDescBy sorts by returned keys descending",
      linearDescTagged == {*((2) "first-two", (2) "second-two", (1) "one", (0) "zero")},
    )
} in !

def TestStreamCombinators : [Test] ! = [test] do {
  let numbers = *(1, 2, 3, 4)
  let transformed = numbers
    ->Stream.FromList
    ->Stream.Map(box [n] n * 2)
    ->Stream.Filter(box [n] n > 4)
    ->Stream.ToList
    ->Try.Ok

  let firstTwo = numbers
    ->Stream.FromList
    ->Stream.Take(2)
    ->Stream.ToList
    ->Try.Ok

  let withoutTwo = numbers
    ->Stream.FromList
    ->Stream.Drop(2)
    ->Stream.ToList
    ->Try.Ok

  let (status) total = {0}->Stream.ForEach(
    numbers->Stream.FromList,
    box [sum, n] sum + n,
  )

  test
    .assert("Stream.Map and Stream.Filter compose", transformed == {*(6, 8)})
    .assert("Stream.Take limits a stream", firstTwo == {*(1, 2)})
    .assert("Stream.Drop skips a prefix", withoutTwo == {*(3, 4)})
    .assert("Stream.ForEach folds while preserving status", status is .ok! and total == 10)
    .assert("Stream.All checks every item", numbers->Stream.FromList->Stream.All(box [n] n > 0)->Try.Ok)
    .assert("Stream.Any short-circuits on a match", numbers->Stream.FromList->Stream.Any(box [n] n == 3)->Try.Ok)
    .assert("Stream.Sum adds numeric items", numbers->Stream.FromList->Stream.Sum->Try.Ok == 10)
} in !

def TestStreamFlattening : [Test] ! = [test] do {
  let stream1 = {*(1, 2)}->Stream.FromList
  let stream2 = {*(3)}->Stream.FromList
  let stream3 = {*(4, 5)}->Stream.FromList
  let nested = *(stream1, stream2, stream3)

  let concatenated = nested->Stream.Concat->Stream.ToList->Try.Ok

  let flatMapped = {*(1, 2, 3)}
    ->Stream.FromList
    ->Stream.FlatMap(box [n] Stream.FromList(*(n, n * 10)))
    ->Stream.ToList
    ->Try.Ok

  test
    .assert("Stream.Concat joins a list of streams", concatenated == {*(1, 2, 3, 4, 5)})
    .assert("Stream.FlatMap maps and flattens streams", flatMapped == {*(1, 10, 2, 20, 3, 30)})
} in !

def TestStreamSplitting : [Test] ! = [test] do {
  let lines = String.Parse("alpha\nbeta\ngamma")
    ->String.Lines
    ->Stream.ToList
    ->Try.Ok

  let windowsLines = String.Parse("alpha\r\nbeta\r\ngamma")
    ->String.Lines
    ->Stream.ToList
    ->Try.Ok

  let stringParts = String.Parse("red::green::blue")
    ->String.SplitBy("::")
    ->Stream.ToList
    ->Try.Ok

  let remainder = String.Parse("remaining")->String.Remainder->Try.Ok

  let bytesRemainder = Bytes.Parse("bytes")->Bytes.Remainder->Try.Ok

  let bytesParts = Bytes.Parse("a,b,c")
    ->Bytes.SplitBy(",")
    ->Stream.Map(box String.FromBytes)
    ->Stream.ToList
    ->Try.Ok

  test
    .assert("String.Lines returns a stream of lines", lines == {*("alpha", "beta", "gamma")})
    .assert("String.Lines accepts Windows line separators", windowsLines == {*("alpha", "beta", "gamma")})
    .assert("String.SplitBy splits by string separators", stringParts == {*("red", "green", "blue")})
    .assert("String.Remainder returns unparsed input", remainder == "remaining")
    .assert("Bytes.Remainder returns unparsed input", String.FromBytes(bytesRemainder) == "bytes")
    .assert("Bytes.SplitBy splits byte streams", bytesParts == {*("a", "b", "c")})
} in !

def TestTextCasingAndTrimming : [Test] ! = [test] do {
  test
    .assert("Char.ToLower lowercases a character", Char.ToLower("A") == "a")
    .assert("Char.ToUpper uppercases a character", Char.ToUpper("z") == "Z")
    .assert("String.ToLower lowercases a string", String.ToLower("Hello WORLD") == "hello world")
    .assert("String.ToUpper uppercases a string", String.ToUpper("Hello world") == "HELLO WORLD")
    .assert("String.Trim trims surrounding whitespace", String.Trim(" \tHello\n") == "Hello")
    .assert("String.TrimLeft trims one leading pattern", String.TrimLeft("::value::", .str "::") == "value::")
    .assert("String.TrimLeft keeps strings without the pattern", String.TrimLeft("value::", .str "::") == "value::")
    .assert("String.TrimRight trims one trailing pattern", String.TrimRight("::value::", .str "::") == "::value")
    .assert("Bytes.TrimLeft trims one leading pattern", String.FromBytes(Bytes.TrimLeft("--data--", .bytes "--")) == "data--")
    .assert("Bytes.TrimRight trims one trailing pattern", String.FromBytes(Bytes.TrimRight("--data--", .bytes "--")) == "--data")
} in !

def TestMapConstructors : [Test] ! = [test] do {
  let source = *((KeyA) "old", (KeyB) "zero", (KeyA) "new")
  let map = Map.FromList(type String, source)
  let (entry) entries = MapLookupThenList(map, KeyA)

  let empty = Map.New(type Key, type String)
  let (emptySize) emptyEntries = MapSizeThenList(empty)

  test
    .assert("Map.FromList keeps the last duplicate key", entry is .some value and value == "new")
    .assert("Map.FromList lists entries in data-key order", entries == {*((KeyB) "zero")})
    .assert("Map.New starts empty", emptySize == 0 and emptyEntries == {*()})
    .assert("Map.entry can insert into a new map", MapPutList(!) == {*((KeyA) "one")})
} in !

def TestBoxMapConstructors : [Test] ! = [test] do {
  let source = *((KeyA) "old", (KeyB) "zero", (KeyA) "new")
  let map = BoxMap.FromList(source)
  let empty = BoxMap.New(type Key, type String)
  let inserted = map.put(KeyC, "two")
  let deleted = inserted.delete(KeyB)

  test
    .assert("BoxMap.FromList keeps the last duplicate key", map.get(KeyA) is .some value and value == "new")
    .assert("BoxMap.FromList exposes plain values from get", map.get(KeyB) is .some value and value == "zero")
    .assert("BoxMap.FromList lists entries in data-key order", map.list == {*((KeyB) "zero", (KeyA) "new")})
    .assert("BoxMap.New starts empty", empty.size == 0 and empty.list == {*()})
    .assert("BoxMap.put returns an updated map", inserted.get(KeyC) is .some value and value == "two")
    .assert("BoxMap.delete returns an updated map", deleted.get(KeyB) is .none!)
} in !

def TestNumberParsingOptions : [Test] ! = [test] do {
  test
    .assert("Int.FromString returns .some for valid integers", Int.FromString("-42") is .some n and n == -42)
    .assert("Int.FromString returns .none! for invalid integers", Int.FromString("x") is .none!)
    .assert("Nat.FromString returns .some for valid naturals", Nat.FromString("42") is .some n and n == 42)
    .assert("Nat.FromString returns .none! for negative integers", Nat.FromString("-1") is .none!)
    .assert("Float.FromString returns .some for valid floats", Float.FromString("1.5") is .some n and Float.Equals(n, 1.5, 0.0))
    .assert("Float.FromString returns .none! for invalid floats", Float.FromString("x") is .none!)
} in !

def TestJsonEqualsWithoutListEquals : [Test] ! = [test] do {
  let object1: Json = .object BoxMap.FromList(type List<(String) Json> in *(
    ("b") .list *(.number 1.0, .number 2.0),
    ("a") .string "x",
  ))
  let object2: Json = .object BoxMap.FromList(type List<(String) Json> in *(
    ("a") .string "x",
    ("b") .list *(.number 1.0, .number 2.0),
  ))
  let object3: Json = .object BoxMap.FromList(type List<(String) Json> in *(
    ("a") .string "x",
    ("b") .list *(.number 1.0, .number 3.0),
  ))

  test
    .assert("Json.Equals still compares object contents", Json.Equals(object1, object2))
    .assert("Json.Equals still rejects different nested list contents", not Json.Equals(object1, object3))
} in !
