module BasicModernization

import {
  @core/String
  @core/Test
  @basic/Os
}

def TestOsMutationHelpers : [Test] ! = [test] do {
  let root = Os.Path(".par-os-modernization-test")
  let sourceFile = root.append("source.txt")
  let movedFile = root.append("moved.txt")
  let sourceDir = root.append("source-dir")
  let movedDir = root.append("moved-dir")

  let scenario =
    catch e => .err e in
    do {
      let _ = Os.RemoveFile(sourceFile)
      let _ = Os.RemoveFile(movedFile)
      let _ = Os.RemoveDir(sourceDir)
      let _ = Os.RemoveDir(movedDir)
      let _ = Os.RemoveDir(root)

      Os.CreateDir(root).try

      let try writer = Os.CreateOrReplaceFile(sourceFile)
      writer.close.try

      Os.MoveFile(sourceFile, movedFile).try

      let try reader = Os.OpenFile(movedFile)
      let try content = String.ReadAll(reader)

      Os.RemoveFile(movedFile).try
      Os.CreateDir(sourceDir).try
      Os.MoveDir(sourceDir, movedDir).try
      Os.RemoveDir(movedDir).try
      Os.RemoveDir(root).try
    } in .ok content

  test.assert(
    "Os remove and move helpers mutate files and directories",
    scenario is .ok content and content == "",
  )
} in !
